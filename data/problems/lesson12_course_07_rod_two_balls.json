    {
      "stepId": 1,
      "title": "写速度约束",
      "content": "两球固定在同一刚性杆上，角速度相同。因 \\(OA=L\\)、\\(OB=L/2\\)，有 \\(v_A=\\omega L\\)，\\(v_B=\\omega L/2=v_A/2\\)。",
      "knowledge": [
        "刚体转动"
      ],
      "commonMistakes": [
        "误认为两球线速度相同"
      ]
    },
    {
      "stepId": 2,
      "title": "计算重力势能减少量",
      "content": "杆由水平转到竖直向下，A 下降 \\(L\\)，B 下降 \\(L/2\\)，故总势能减少 \\(\\Delta E_p=mgL+mg\\frac L2=\\frac32mgL\\)。",
      "knowledge": [
        "重力势能"
      ],
      "commonMistakes": []
    },
    {
      "stepId": 3,
      "title": "列系统机械能守恒",
      "content": "\\(\\frac32mgL=\\frac12mv_A^2+\\frac12mv_B^2=\\frac12m\\omega^2L^2(1+\\frac14)\\)。解得 \\(\\omega^2=\\frac{12g}{5L}\\)，从而 \\(v_A=\\sqrt{\\frac{12}{5}gL}\\)，\\(v_B=\\sqrt{\\frac35gL}\\)。",
      "knowledge": [
        "机械能守恒"
      ],
      "commonMistakes": [
        "漏掉中点小球的动能"
      ]
    }
  ],
